# ─────────────────────────────────────────────────────────────
#  Backlog Quality Gate — Environment Configuration
#  Copy this file to .env and fill in your values:
#    cp .env.example .env   (Linux/macOS)
#    copy .env.example .env (Windows)
# ─────────────────────────────────────────────────────────────

# Grok API key — obtain from https://console.x.ai
GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Grok model to use
# Recommended options:
#   grok-3-mini   — fast, cost-efficient (default)
#   grok-3        — higher quality, slower
#   grok-4.20     — latest reasoning model
GROK_MODEL=grok-3-mini

# Port the Express server listens on
PORT=5000
